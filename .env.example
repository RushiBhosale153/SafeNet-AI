# 🔐 SafeNet AI - .env.example

# Server Engine
PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_here
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/safenet

# --- Threat Intelligence API Keys ---

# VirusTotal (Mandatory for Reputation)
VT_API_KEY=your_virustotal_api_key

# Google Safe Browsing (Highly Recommended)
GOOGLE_SAFE_BROWSING_API_KEY=your_google_cloud_api_key

# urlscan.io (For Behavioral Analysis)
URLSCAN_API_KEY=your_urlscan_api_key

# AbuseIPDB (For IP Reputation)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key

# OTX AlienVault (Indicator Enrichment)
OTX_API_KEY=your_alienvault_otx_key

# PhishTank (Community Phishing Data)
PHISHTANK_API_KEY=your_phishtank_api_key

# --- Supporting Services ---

# Identification Breach Intelligence
LEAKCHECK_API_KEY=your_leakcheck_api_key

# Gemini AI (For Automated Security Summaries)
GEMINI_API_KEY=your_google_ai_studio_key

# Email Service (Resend)
EMAIL_SERVICE_KEY=your_resend_api_key

# ⚠️ WARNING: Never commit your actual .env file to version control.