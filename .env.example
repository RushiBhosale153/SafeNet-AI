# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/safenet-ai

# API Keys
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
LEAKCHECK_API_KEY=your_leakcheck_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Email Service (Resend)
EMAIL_SERVICE_KEY=your_resend_api_key_here

# JWT Secret
JWT_SECRET=your_super_secure_jwt_secret_min_32_characters

# Server Configuration
PORT=5000
NODE_ENV=development